env
# ─────────────────────────────────────────────────────────────────────────────
# LogiSense AI — Backend Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────────────────────────────────────

# Path to your Kaggle supply chain CSV
DATA_PATH=./data/supply_chain.csv

# Path to save/load trained ML models
MODEL_PATH=./models

# Server settings
HOST=0.0.0.0
PORT=8000

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# External APIs
OPENROUTESERVICE_API_KEY=your_key_here
OPENWEATHER_API_KEY=your_key_here
# Nominatim uses no key