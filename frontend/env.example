env
# ─────────────────────────────────────────────────────────────────────────────
# LogiSense AI — Backend Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────────────────────────────────────

# Path to your Kaggle supply chain CSV
DATA_PATH=./data/supply_chain.csv

# Path to save/load trained ML models
MODEL_PATH=./models

# Server settings
HOST=0.0.0.0
PORT=8000

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# External APIs
OPENROUTESERVICE_API_KEY=your_key_here
OPENWEATHER_API_KEY=your_key_here
# Nominatim uses no key
# ── Optional: Real road routing (OpenRouteService) ────────────────────────────
# Get a FREE key at: https://openrouteservice.org/dev/#/signup (2000 req/day)
# Without this, straight-line distances are used (still functional)
OPENROUTESERVICE_API_KEY=YOUR_KEY_HERE