# ─────────────────────────────────────────────────────────────────────────────
# LogiSense AI — Backend Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────────────────────────────────────

# Path to your Kaggle supply chain CSV
# Download from: https://www.kaggle.com/datasets/harshsingh2209/supply-chain-analysis
DATA_PATH=./data/supply_chain.csv

# Path to save/load trained ML models (auto-created)
MODEL_PATH=./models

# Server settings
HOST=0.0.0.0
PORT=8000

# CORS — must match your frontend URL exactly
FRONTEND_URL=http://localhost:5173

# ── Optional: Real weather data ───────────────────────────────────────────────
# Get a FREE key at: https://openweathermap.org/api (free tier is sufficient)
# Without this, simulated regional weather data is used automatically
OPENWEATHER_API_KEY=YOUR_KEY_HERE
